{
  "title": "RAG Metrics",
  "uid": "daemoniq-rag",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["rag", "daemoniq"],
  "panels": [
    {
      "id": 1,
      "title": "Total Queries",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] }, "unit": "short" }
      },
      "targets": [
        {
          "expr": "sum(daemoniq_rag_rag_queries_total)",
          "legendFormat": "Queries"
        }
      ]
    },
    {
      "id": 2,
      "title": "Query Rate (last 5m)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "orientation": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] }, "unit": "reqps", "decimals": 2 }
      },
      "targets": [
        {
          "expr": "sum(rate(daemoniq_rag_rag_queries_total[5m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 3,
      "title": "Avg Query Latency",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5000 },
            { "color": "red", "value": 30000 }
          ]}
        }
      },
      "targets": [
        {
          "expr": "sum(rate(daemoniq_rag_rag_query_latency_milliseconds_sum[5m])) / sum(rate(daemoniq_rag_rag_query_latency_milliseconds_count[5m]))",
          "legendFormat": "Avg latency"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg LLM Latency",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 3000 },
            { "color": "red", "value": 20000 }
          ]}
        }
      },
      "targets": [
        {
          "expr": "sum(rate(daemoniq_rag_rag_llm_latency_milliseconds_sum[5m])) / sum(rate(daemoniq_rag_rag_llm_latency_milliseconds_count[5m]))",
          "legendFormat": "Avg LLM latency"
        }
      ]
    },
    {
      "id": 5,
      "title": "Avg Chunks Retrieved",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "purple", "value": null }] }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(daemoniq_rag_rag_chunks_retrieved_sum[5m])) / sum(rate(daemoniq_rag_rag_chunks_retrieved_count[5m]))",
          "legendFormat": "Avg chunks"
        }
      ]
    },
    {
      "id": 6,
      "title": "Query Latency Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(daemoniq_rag_rag_query_latency_milliseconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(daemoniq_rag_rag_query_latency_milliseconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(daemoniq_rag_rag_query_latency_milliseconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 7,
      "title": "LLM vs Retrieval Latency",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(daemoniq_rag_rag_llm_latency_milliseconds_sum[5m])) / sum(rate(daemoniq_rag_rag_llm_latency_milliseconds_count[5m]))",
          "legendFormat": "LLM (avg)"
        },
        {
          "expr": "sum(rate(daemoniq_rag_rag_retrieval_latency_milliseconds_sum[5m])) / sum(rate(daemoniq_rag_rag_retrieval_latency_milliseconds_count[5m]))",
          "legendFormat": "Retrieval (avg)"
        }
      ]
    },
    {
      "id": 8,
      "title": "Query Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 20 } }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(daemoniq_rag_rag_queries_total[2m])) by (mode)",
          "legendFormat": "{{mode}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Chunks Retrieved Distribution",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(daemoniq_rag_rag_chunks_retrieved_bucket[5m])) by (le))",
          "legendFormat": "p50 chunks"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(daemoniq_rag_rag_chunks_retrieved_bucket[5m])) by (le))",
          "legendFormat": "p95 chunks"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "pluginId": "prometheus",
        "hide": 2
      }
    ]
  }
}
